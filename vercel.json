{
  "version": 2,
  "builds": [
    {
      "src": "backend/Server.js",
      "use": "@vercel/node"
    },
    {
      "src": "frontend/package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "build" }
    }
  ],
  "rewrites": [
    { "source": "/compare", "destination": "/backend/Server.js" },
    { "source": "/share/(.*)", "destination": "/backend/Server.js" },
    { "source": "/(.*)", "destination": "/frontend/$1" }
  ]
}